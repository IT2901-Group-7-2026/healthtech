# Database configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=healthtech
POSTGRES_PORT=5432
# IMPORTANT: Update this connection string to match the variables above
# For production: Host=db;... (use the service name for the database defined in docker-compose.prd.yml)
DATABASE_URL=Host=localhost;Port=5432;Database=healthtech;Username=postgres;Password=your_secure_password

# Application configuration (this stays unchanged for production)
DOTNET_APP_PORT=5063
ALLOWED_HOST=localhost
